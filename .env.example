# ===============================
# v12 SYNDICATE INFRA ENGINE
# .env.example
# ===============================

# ===== API =====
ODDS_API_KEY=your_odds_api_key_here

# ===== EMAIL REPORT =====
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password_here
GMAIL_RECEIVER=receiver_email@gmail.com

# ===== BANKROLL =====
AKTUALNY_BANK=1000
KELLY_FRAC=0.0075
MAX_STAKE_PCT=0.005
MIN_STAKE=1

# ===== EDGE FILTERS =====
MIN_EDGE=0.08
MAX_EDGE=0.13
MIN_PROB=0.20
MAX_ODDS=4.50

# ===== LONGSHOT FILTER =====
LONGSHOT_MAX_ODDS=4.00
LONGSHOT_MIN_EDGE=0.14
LONGSHOT_MIN_PROB=0.24

# ===== DAILY RISK =====
TOP_N_REPORT=2
MAX_BETS_PER_DAY=2
MAX_DAILY_EXPOSURE_PCT=0.03
MAX_MATCH_EXPOSURE_PCT=0.01
MAX_LEAGUE_EXPOSURE_PCT=0.025

# ===== MARKET CONSENSUS =====
MARKET_BLEND_WEIGHT=0.55
MIN_MARKET_EDGE=0.04
MIN_BOOKMAKERS_AGREE=2
REQUIRE_MARKET_AGREEMENT=1

# ===== MODEL =====
PROB_SHRINK=0.72
DIXON_COLES_RHO=-0.08
RECENT_MATCHES=8
MAX_GOALS_GRID=10

# ===== AI =====
AI_FILTER_ENABLED=0
MIN_AI_PROB=0.56
MIN_AI_EDGE=0.02

# ===== ELO =====
ELO_ENABLED=1
ELO_BASE=1500
ELO_K=22
ELO_HOME_ADV=65

# ===== META LAYER =====
META_LAYER_ENABLED=1
META_MIN_CONFIDENCE=0.60
META_REDUCE_BELOW=0.72

# ===== CLV =====
SNAPSHOT_ODDS=1
CLV_LOOKBACK_HOURS=12
CLV_MODEL_MIN_SAMPLES=25

# ===== STEAM / ODDS MOVEMENT =====
LINE_MOVE_GOOD_PCT=0.01
LINE_MOVE_BAD_PCT=-0.02

# ===== LIVE BETTING =====
LIVE_MODE_ENABLED=0
LIVE_REQUIRE_STEAM=1
LIVE_MIN_EDGE=0.10
LIVE_MAX_MINUTE=70

# ===== INJURY / NEWS =====
INJURY_NEWS_ENABLED=0
INJURY_SOURCE_FILE=injury_news_sample.json

# ===== DATABASE =====
DB_FILE=bets.db
CACHE_DIR=cache
EXPORT_DIR=exports

# ===== PERFORMANCE =====
CACHE_TTL_SECONDS=3600
HTTP_TIMEOUT=30
LOOKAHEAD_HOURS=72

# ===== TIMEZONE =====
LOCAL_TZ=Europe/Bratislava

# ===== LOGGING =====
LOG_LEVEL=INFO

# ===== COLLECTOR =====
ODDS_COLLECTOR_ENABLED=1
COLLECTOR_INTERVAL_SECONDS=300

# ===== MONTE CARLO =====
MC_SIMULATIONS=10000
MC_YEARS=1

# ===== ANALYTICS =====
ANALYTICS_DAYS=365
BACKTEST_DAYS=180

# ===== MULTISPORT =====
SPORT_MODE=all
SPORT_CONCURRENCY=5

# ===== TELEGRAM =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_CONFIDENCE=80

# ===== DASHBOARD =====
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# ===== PRO TIPPER =====
TOP_TIPS_LIMIT=5
MIN_CONFIDENCE=65
SAVE_AUDIT_LOG=1

# ===== CONSENSUS ENGINE =====
CONSENSUS_ENABLED=1

ELO_WEIGHT=0.25
XG_WEIGHT=0.25
FORM_WEIGHT=0.20
MARKET_WEIGHT=0.20
CONTEXT_WEIGHT=0.10

# ===== AUTO LEARNING =====
LEARNING_ENABLED=1
LEARNING_MIN_SAMPLES=20
LEARNING_RETRAIN_AFTER_SCAN=1

# ===== BANKROLL (Kelly Engine) =====
BANKROLL=1000
MAX_STAKE_PERCENT=0.03
KELLY_FRACTION=0.25

# ===== REPORT =====
REPORT_SAVE_HISTORY=1
REPORT_SAVE_LATEST=1
EMAIL_TOP_TIPS_ONLY=1
